<?xml version="1.0"?>
<!-- Dual-channel MDROBOT controller (e.g. PNT50, MD400T) as a ros2_control
     system. Laid out as a 2-wheel differential base so diff_drive_controller
     can drive it directly. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mdrobot_dual">

  <xacro:arg name="port" default="/dev/ttyUSB0"/>
  <xacro:arg name="baudrate" default="19200"/>
  <xacro:arg name="motor_id" default="1"/>
  <xacro:arg name="use_limit_sw" default="-1"/>
  <xacro:arg name="auto_enable" default="true"/>
  <!-- PNT50 measured 2026-06-22: 12 counts/rev both motors (hall, =3 x 4-pole). -->
  <xacro:arg name="counts_per_rev" default="12.0"/>

  <link name="base_link"/>
  <link name="motor1_link"/>
  <link name="motor2_link"/>
  <joint name="motor1" type="continuous">
    <parent link="base_link"/>
    <child link="motor1_link"/>
    <origin xyz="0 0.15 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <joint name="motor2" type="continuous">
    <parent link="base_link"/>
    <child link="motor2_link"/>
    <origin xyz="0 -0.15 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <ros2_control name="mdrobot_dual" type="system">
    <hardware>
      <plugin>mdrobot_ros2_control/MdrobotSystemHardware</plugin>
      <param name="device_type">dual</param>
      <param name="port">$(arg port)</param>
      <param name="baudrate">$(arg baudrate)</param>
      <param name="motor_id">$(arg motor_id)</param>
      <param name="use_limit_sw">$(arg use_limit_sw)</param>
      <param name="auto_enable">$(arg auto_enable)</param>
      <param name="position_max_rpm">100</param>
    </hardware>
    <joint name="motor1">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <param name="counts_per_rev">$(arg counts_per_rev)</param>
    </joint>
    <joint name="motor2">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
      <param name="counts_per_rev">$(arg counts_per_rev)</param>
    </joint>
  </ros2_control>
</robot>
